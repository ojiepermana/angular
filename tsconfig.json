/* To learn more about Typescript configuration file: https://www.typescriptlang.org/docs/handbook/tsconfig-json.html. */
/* To learn more about Angular compiler options: https://angular.dev/reference/configs/angular-compiler-options. */
{
  "compileOnSave": false,
  "compilerOptions": {
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "paths": {
      "@ojiepermana/angular": ["./projects/library/public-api.ts"],
      "@ojiepermana/angular/layouts": ["./projects/library/layouts/public-api.ts"],
      "@ojiepermana/angular/theme": ["./projects/library/theme/public-api.ts"],
      "@ojiepermana/angular/theme/component": ["./projects/library/theme/component/public-api.ts"],
      "@ojiepermana/angular/theme/directive": ["./projects/library/theme/directive/public-api.ts"],
      "@ojiepermana/angular/theme/service": ["./projects/library/theme/service/public-api.ts"],
      "library": ["./projects/library/public-api.ts"],
      "library/layouts": ["./projects/library/layouts/public-api.ts"],
      "library/theme": ["./projects/library/theme/public-api.ts"],
      "library/theme/component": ["./projects/library/theme/component/public-api.ts"],
      "library/theme/directive": ["./projects/library/theme/directive/public-api.ts"],
      "library/theme/service": ["./projects/library/theme/service/public-api.ts"]
    },
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "preserve"
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "strictTemplates": true
  },
  "files": [],
  "references": [
    {
      "path": "./projects/demo/tsconfig.app.json"
    },
    {
      "path": "./projects/demo/tsconfig.spec.json"
    },
    {
      "path": "./projects/library/tsconfig.lib.json"
    },
    {
      "path": "./projects/library/tsconfig.spec.json"
    }
  ]
}
