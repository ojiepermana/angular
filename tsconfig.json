/* To learn more about Typescript configuration file: https://www.typescriptlang.org/docs/handbook/tsconfig-json.html. */
/* To learn more about Angular compiler options: https://angular.dev/reference/configs/angular-compiler-options. */
{
  "compileOnSave": false,
  "compilerOptions": {
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "paths": {
      "angular": ["./dist/angular"],
      "@ojiepermana/angular": ["./projects/angular/public-api.ts"],
      "@ojiepermana/angular/theme": ["./projects/angular/theme/public-api.ts"],
      "@ojiepermana/angular/navigation": ["./projects/angular/navigation/public-api.ts"],
      "@ojiepermana/angular/component": ["./projects/angular/component/public-api.ts"],
      "@ojiepermana/angular/layout": ["./projects/angular/layout/public-api.ts"],
      "@ojiepermana/angular/chart": ["./projects/angular/chart/public-api.ts"],
      "@ojiepermana/angular/etos": ["./projects/angular/brand/etos/public-api.ts"],
      "@ojiepermana/angular/etos/shell/layout": ["./projects/angular/brand/etos/shells/layouts/etos.layout.ts"],
      "@ojiepermana/angular/etos/shell/pages": [
        "./projects/angular/brand/etos/shells/pages/shell-pages/shell-pages.ts"
      ],
      "@ojiepermana/angular/etos/styles": ["./projects/angular/brand/etos/themes/index.css"],
      "@ojiepermana/angular/etos/styles/*": ["./projects/angular/brand/etos/themes/*"],
      "@ojiepermana/angular/generator/api": ["./projects/angular/generator/api/public-api.ts"]
    },
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler"
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "strictTemplates": true
  },
  "files": [],
  "references": [
    {
      "path": "./projects/angular/tsconfig.lib.json"
    },
    {
      "path": "./projects/angular/tsconfig.spec.json"
    },
    {
      "path": "./projects/demo/library/tsconfig.app.json"
    },
    {
      "path": "./projects/demo/library/tsconfig.spec.json"
    },
    {
      "path": "./projects/demo/etos/tsconfig.app.json"
    },
    {
      "path": "./projects/demo/etos/tsconfig.spec.json"
    },
    {
      "path": "./projects/demo/ala/tsconfig.app.json"
    },
    {
      "path": "./projects/demo/ala/tsconfig.spec.json"
    }
  ]
}
