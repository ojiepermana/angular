{
  "name": "angular",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "build": "bun run gen:sdk:build && bun run gen:guide:build && ng build angular && node projects/angular/scripts/prepare-package.mjs",
    "watch": "ng build angular --watch --configuration development",
    "test": "ng test angular",
    "test:theme": "ng run angular:test-theme --watch=false",
    "gen:sdk:build": "tsc -p projects/angular/generator/api/tsconfig.schematics.json",
    "gen:sdk:init": "bun run gen:sdk:build && ng generate ./projects/angular/collection.json:sdk-init",
    "gen:sdk": "bun run gen:sdk:build && ng generate ./projects/angular/collection.json:sdk",
    "gen:guide:build": "tsc -p projects/angular/generator/guide/tsconfig.schematics.json",
    "gen:guide:init": "bun run gen:guide:build && ng generate ./projects/angular/collection.json:guide-init",
    "gen:guide": "bun run gen:guide:build && ng generate ./projects/angular/collection.json:guide",
    "publish": "bun projects/angular/scripts/publish.mjs",
    "format": "prettier --write \"**/*.{ts,js,json,html,css,scss,md}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,html,css,scss,md}\""
  },
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ojiepermana/angular.git"
  },
  "homepage": "https://github.com/ojiepermana/angular#readme",
  "bugs": {
    "url": "https://github.com/ojiepermana/angular/issues"
  },
  "packageManager": "bun@1.3.6",
  "dependencies": {
    "@angular/animations": "^21.2.9",
    "@angular/cdk": "^21.2.7",
    "@angular/common": "^21.2.9",
    "@angular/compiler": "^21.2.9",
    "@angular/core": "^21.2.9",
    "@angular/forms": "^21.2.9",
    "@angular/material": "^21.2.7",
    "@angular/platform-browser": "^21.2.9",
    "@angular/router": "^21.2.9",
    "@ojiepermana/angular": "^21.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3-array": "^3.2.4",
    "d3-axis": "^3.0.0",
    "d3-format": "^3.1.2",
    "d3-interpolate": "^3.0.1",
    "d3-scale": "^4.0.2",
    "d3-selection": "^3.0.0",
    "d3-shape": "^3.2.0",
    "d3-time": "^3.1.0",
    "d3-time-format": "^4.1.0",
    "d3-transition": "^3.0.1",
    "marked": "^18.0.2",
    "rxjs": "~7.8.2",
    "tailwind-merge": "^3.5.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular-devkit/core": "^21.2.7",
    "@angular-devkit/schematics": "^21.2.7",
    "@angular/build": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.9",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/d3-array": "^3.2.2",
    "@types/d3-axis": "^3.0.6",
    "@types/d3-format": "^3.0.4",
    "@types/d3-interpolate": "^3.0.4",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-shape": "^3.1.8",
    "@types/d3-time": "^3.0.4",
    "@types/d3-time-format": "^4.0.3",
    "@types/d3-transition": "^3.0.9",
    "@types/node": "^25.6.0",
    "jsdom": "^28.1.0",
    "ng-packagr": "^21.2.3",
    "postcss": "^8.5.10",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "vitest": "^4.1.4",
    "yaml": "^2.8.3"
  }
}