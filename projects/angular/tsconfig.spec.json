/* To learn more about Angular compiler options: https://angular.dev/reference/configs/angular-compiler-options. */
{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "../../out-tsc/spec",
    "types": ["vitest/globals"]
  },
  "include": [
    "component/src/**/*.d.ts",
    "component/src/**/*.spec.ts",
    "brand/etos/**/*.d.ts",
    "brand/etos/**/*.spec.ts",
    "etos/**/*.d.ts",
    "etos/**/*.spec.ts",
    "theme/src/**/*.d.ts",
    "theme/src/**/*.spec.ts",
    "layout/src/**/*.d.ts",
    "layout/src/**/*.spec.ts",
    "navigation/src/**/*.d.ts",
    "navigation/src/**/*.spec.ts",
    "chart/src/**/*.d.ts",
    "chart/src/**/*.spec.ts"
  ]
}
